{
    "layer": "top",
    "position": "bottom",
    "height": 22,
    "modules-left": ["clock", "custom/clock2"],
    // "modules-center": ["wlr/taskbar"],
    "modules-right": ["idle_inhibitor", "memory", "cpu", "custom/ping", "network", "tray", "pulseaudio", "battery"],
    "custom/ping": {
        "exec": "s ping",
        "interval": 3,
        "tooltip": false,
        "format": "{}MS"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "tooltip": false,
        "format-icons": {
            "activated": "!I",
            "deactivated": "I"
        }
    },
    "cpu": {
        "format": "C{usage}",
        "interval": "1",
        "tooltip": false
    },
    "memory": {
        "interval": 30,
        "format": "M{}",
        "max-length": 10
    },
    "custom/kernel": {
        "exec": "uname -r",
        "interval": "once",
        "tooltip": false
    },
    "tray": {
        "spacing": 5,
        "icon-size": 14,
        "tooltip": false
    },
    "battery": {
        "states": {
            // "good": 95,
            "warning": 20,
            "critical": 10
        },
        "format": "{capacity}% ",
        "format-charging": "{capacity}% ",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        //"format-icons": [" ", " ", " ", " ", " ", " ", " ", " "],
        "tooltip": false,
        "on-click": "footclient htop"
    },
    "clock": {
        "format": "{:%H:%M}",
        "tooltip": false,
        "on-click": "foot calcurse"
    },
    "custom/clock2": {
        "exec": "date +'%^a %d %^b'",
        "interval": 60,
        "tooltip": false,
        "format": "{}"
    },
    "pulseaudio": {
        //"scroll-step": 1,
        "format": "{icon}{volume}",
        "format-bluetooth": "{icon}{volume}",
        "format-muted": "",
        "format-icons": {
            "headphones": "",
            "handsfree": "",
            "headset": "",
            "phone": "",
            "portable": "",
            "car": "",
            "default": ["v", "V"]
        },
        "tooltip": false,
        "on-click": "pavucontrol"
    },
    "network": {
        "format-wifi": "WIFI {signalStrength}",
        "format-ethernet": "ETH",
        "format-disconnected": " ⚠",
        "tooltip": false,
        // "on-click": "footclient nmtui",
    },
    "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": 16,
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-right": "maximize",
        "on-click-middle": "minimize-raise"
    }
}
