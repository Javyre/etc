[colors]
background = #c0000000
background-alt = #aa333333
foreground = #dfdfdf
foreground-alt = #d5d5d5
foreground-dim = #555555
foreground-green = #00b000
primary = #ffb52a
secondary = #ccff0000
alert = #bd2c40

[bar/dark-i3-small]
monitor = DVI-D-1
inherit = bar/dark-i3
height = 18
font-0 = Sans:pixelsize=10;2
font-1 = emoji:scale=9;2
font-2 = Font Awesome 5 Free Solid:pixelsize=8;2
tray-position = none

[bar/dark-i3-small-secondary]
monitor = DVI-I-0
inherit = bar/dark-i3
height = 18
font-0 = Sans:pixelsize=10;2
font-1 = emoji:scale=9;2
font-2 = Font Awesome 5 Free Solid:pixelsize=8;2
modules-right = mpd date
padding-right = 1
tray-position = right

[bar/dark-i3-big]
monitor = DisplayPort-0
inherit = bar/dark-i3

[bar/dark-i3]
monitor = eDP1
inherit = bar/dark
wm-restack = i3
scroll-up = i3wm-wsnext
scroll-down = i3wm-wsprev
modules-left = xbacklight i3 

[bar/dark]
width = 100%
height = 27
fixed-center = false
background = ${colors.background}
foreground = ${colors.foreground}

;line-size = 2
line-color = #f00

; border-size = 4
; border-color = #00000000

padding-left = 0
padding-right = 0

module-margin-left = 1
module-margin-right = 1

font-0 = Sans:pixelsize=13;3
;font-0 = emoji:scale=9;2
; font-1 = unifont:fontformat=truetype:size=8:antialias=false;0
font-1 = emoji:scale=9;2
;font-0 = "Font Awesome 5 Free Solid:pixelsize=10;1"
font-2 = Font Awesome 5 Free Solid:pixelsize=12;3

modules-left = xbacklight bspwm
modules-center = xwindow
; modules-right = filesystem xbacklight alsa pulseaudio xkeyboard memory cpu wlan eth battery temperature date powermenu
modules-right = filesystem memory cpu battery xkeyboard pulseaudio wlan temperature date powermenu

tray-position = right
tray-padding = 2
;tray-transparent = true
;tray-background = #0063ff

wm-restack = bspwm
;wm-restack = i3

;override-redirect = true

scroll-up = bspwm-desknext
scroll-down = bspwm-deskprev

;scroll-up = i3wm-wsnext
;scroll-down = i3wm-wsprev

cursor-click = pointer
cursor-scroll = ns-resize

[module/xwindow]
type = internal/xwindow
label = %title:0:60:...%

[module/xkeyboard]
type = internal/xkeyboard
blacklist-0 = num lock

format-prefix = "яХ╜ "
format-prefix-font = 3
format-prefix-foreground = ${colors.foreground}
format-prefix-underline = ${colors.secondary}

label-layout = %layout%
label-layout-underline = ${colors.secondary}

label-indicator-padding = 2
label-indicator-margin = 1
label-indicator-background = ${colors.secondary}
label-indicator-underline = ${colors.secondary}

[module/filesystem]
type = internal/fs
interval = 25

mount-0 = /

label-mounted = %{F#0a81f5}%mountpoint%%{F-}: %percentage_used%%
label-unmounted = %mountpoint% not mounted
label-unmounted-foreground = ${colors.foreground-alt}

[module/bspwm]
type = internal/bspwm

label-focused = %icon%
label-focused-font = 3
label-focused-background = ${colors.background-alt}
label-focused-underline= ${colors.primary}
label-focused-padding = 1

label-occupied = %icon%
label-occupied-font = 3
label-occupied-padding = 1

label-urgent = %icon%!
label-urgent-font = 3
label-urgent-background = ${colors.alert}
label-urgent-padding = 1

label-empty = %icon%
;label-empty = яЖТ
label-empty-font = 3
label-empty-foreground = ${colors.foreground-dim}
label-empty-padding = 1

; Separator in between workspaces
; label-separator = |

ws-icon-0 = I;яДб
ws-icon-1 = II;яЛР
ws-icon-2 = III;яАК
ws-icon-3 = IV;яДа
ws-icon-4 = VIII;яЦн
ws-icon-5 = IX;яГН
ws-icon-6 = X;яД╡
;ws-icon-default = "яДС"
ws-icon-default = яФЫ

[module/i3]
type = internal/i3
format = <label-state> <label-mode>
index-sort = true
wrapping-scroll = false

; Only show workspaces on the same output as the bar
pin-workspaces = true

label-mode-padding = 2
label-mode-foreground = #000
label-mode-background = ${colors.primary}

; focused = Active workspace on focused monitor
label-focused = %index%
label-focused-background = ${module/bspwm.label-focused-background}
label-focused-underline = ${module/bspwm.label-focused-underline}
label-focused-padding = ${module/bspwm.label-focused-padding}

; unfocused = Inactive workspace on any monitor
label-unfocused = %index%
label-unfocused-padding = ${module/bspwm.label-occupied-padding}

; visible = Active workspace on unfocused monitor
label-visible = %index%
label-visible-background = ${self.label-focused-background}
label-visible-underline = ${self.label-focused-underline}
label-visible-padding = ${self.label-focused-padding}

; urgent = Workspace with urgency hint set
label-urgent = %index%
label-urgent-background = ${module/bspwm.label-urgent-background}
label-urgent-padding = ${module/bspwm.label-urgent-padding}

; Separator in between workspaces
; label-separator = |


[module/mpd]
type = internal/mpd
host = 127.0.0.1
port = 6600
password =
interval = 1

format-online = <label-time> <label-song> <icon-prev> <icon-stop> <toggle> <icon-next> 

icon-play = яБЛ
icon-pause = яБМ
icon-stop = яБН
icon-prev = яБЙ
icon-next = яБР

bar-progress-width = 25
bar-progress-indicator = |
bar-progress-fill = тФА
bar-progress-empty = тФА

label-song-maxlen = 25
label-song-ellipsis = true

[module/xbacklight]
type = internal/xbacklight

;format = <ramp> <bar>
format = <ramp>
format-background = ${colors.background-alt}
format-padding = 1
label = BL

ramp-4 = ЁЯМХ
ramp-3 = ЁЯМФ
ramp-2 = ЁЯМУ
ramp-1 = ЁЯМТ
ramp-0 = ЁЯМС
ramp-font = 2

bar-width = 10
bar-indicator = |
bar-indicator-foreground = #fff
bar-indicator-font = 2
bar-fill = тФА
bar-fill-font = 2
bar-fill-foreground = #9f78e1
bar-empty = тФА
bar-empty-font = 2
bar-empty-foreground = ${colors.foreground-alt}

[module/backlight-acpi]
inherit = module/xbacklight
type = internal/backlight
card = intel_backlight

[module/cpu]
type = internal/cpu
interval = 2
format-prefix = "яЛЫ "
format-prefix-foreground = ${colors.foreground-alt}
format-underline = #f90000
label = %percentage:2%%

[module/memory]
type = internal/memory
interval = 2
format-prefix = "яФ╕ "
format-prefix-foreground = ${colors.foreground-alt}
format-underline = #4bffdc
label = %percentage_used%%

[module/wlan]
type = internal/network
interface = wlp2s0
interval = 3.0

format-connected = <ramp-signal> <label-connected>
format-connected-underline = #9f78e1
label-connected = %essid%

format-disconnected =
;format-disconnected = <label-disconnected>
;format-disconnected-underline = ${self.format-connected-underline}
;label-disconnected = %ifname% disconnected
;label-disconnected-foreground = ${colors.foreground-alt}

ramp-signal-0 = ЁЯШ▒
ramp-signal-1 = ЁЯШа
ramp-signal-2 = ЁЯШТ
ramp-signal-3 = ЁЯШК
ramp-signal-4 = ЁЯШГ
ramp-signal-5 = ЁЯШИ
; ramp-signal-0 = юИШ
; ramp-signal-1 = юИЩ
; ramp-signal-2 = юИЪ
; ramp-signal-3 = юИЪ
; ramp-signal-4 = юИЪ
ramp-signal-foreground = ${colors.foreground-alt}
ramp-signal-font = 2

[module/eth]
type = internal/network
interface = eth1
interval = 3.0

format-connected-underline = #55aa55
format-connected-prefix = "юЖЬ "
format-connected-prefix-foreground = ${colors.foreground-alt}
label-connected = %local_ip%

format-disconnected =
;format-disconnected = <label-disconnected>
;format-disconnected-underline = ${self.format-connected-underline}
;label-disconnected = %ifname% disconnected
;label-disconnected-foreground = ${colors.foreground-alt}

[module/date]
type = internal/date
interval = 5

date =
date-alt = " %Y-%m-%d"

time = %H:%M
time-alt = %H:%M:%S

format-prefix = яЮД
format-prefix-foreground = ${colors.foreground-alt}
format-underline = #0a6cf5

label = %date% %time%

[module/pulseaudio]
type = internal/pulseaudio

format-volume = <label-volume> <bar-volume>
label-volume = яАи %percentage%%
label-volume-foreground = ${root.foreground}

label-muted = ЁЯФЗ muted
label-muted-foreground = #666

bar-volume-width = 10
bar-volume-foreground-0 = #55aa55
bar-volume-foreground-1 = #55aa55
bar-volume-foreground-2 = #55aa55
bar-volume-foreground-3 = #55aa55
bar-volume-foreground-4 = #f5a70a
bar-volume-foreground-5 = #f5a70a
bar-volume-foreground-6 = #ff5555
bar-volume-gradient = true
;bar-volume-indicator = |
bar-volume-indicator =
bar-volume-indicator-font = 2
bar-volume-fill = тФА
bar-volume-fill-font = 2
bar-volume-empty = тФА
bar-volume-empty-font = 2
;bar-volume-empty-foreground = ${colors.foreground-alt}
bar-volume-empty-foreground = ${colors.background}

[module/alsa]
type = internal/alsa

format-volume = <label-volume> <bar-volume>
label-volume = VOL
label-volume-foreground = ${root.foreground}

format-muted-prefix = "юИВ "
format-muted-foreground = ${colors.foreground-alt}
label-muted = sound muted

bar-volume-width = 10
bar-volume-foreground-0 = #55aa55
bar-volume-foreground-1 = #55aa55
bar-volume-foreground-2 = #55aa55
bar-volume-foreground-3 = #55aa55
bar-volume-foreground-4 = #55aa55
bar-volume-foreground-5 = #f5a70a
bar-volume-foreground-6 = #ff5555
bar-volume-gradient = false
bar-volume-indicator = |
bar-volume-indicator-font = 2
bar-volume-fill = тФА
bar-volume-fill-font = 2
bar-volume-empty = тФА
bar-volume-empty-font = 2
bar-volume-empty-foreground = ${colors.foreground-alt}

[module/battery]
type = internal/battery
battery = BAT0
adapter = ADP1
full-at = 98

format-charging = <animation-charging> <label-charging>
format-charging-underline = #ffb52a

;format-discharging = <animation-discharging> <label-discharging>
format-discharging = <ramp-capacity> <label-discharging>
format-discharging-underline = ${self.format-charging-underline}

format-full-prefix = "яЙА "
;format-full-prefix-foreground = ${colors.foreground-alt}
format-full-prefix-foreground = ${colors.foreground-green}
format-full-underline = ${self.format-charging-underline}

ramp-capacity-0 = яЙД
ramp-capacity-1 = яЙГ
ramp-capacity-2 = яЙВ
ramp-capacity-3 = яЙБ
ramp-capacity-4 = яЙА
ramp-capacity-foreground = ${colors.foreground-alt}

animation-charging-0 = яЙД
animation-charging-1 = яЙГ
animation-charging-2 = яЙВ
animation-charging-3 = яЙБ
animation-charging-4 = яЙА
animation-charging-foreground = ${colors.foreground-green}
animation-charging-framerate = 1050

animation-discharging-4 = яЙД
animation-discharging-3 = яЙГ
animation-discharging-2 = яЙВ
animation-discharging-1 = яЙБ
animation-discharging-0 = яЙА
animation-discharging-foreground = ${colors.foreground-alt}
animation-discharging-framerate = 1050

[module/temperature]
type = internal/temperature
thermal-zone = 0
warn-temperature = 60

format = <ramp> <label>
format-underline = #f50a4d
format-warn = <ramp> <label-warn>
format-warn-underline = ${self.format-underline}

label = %temperature-c%
label-warn = %temperature-c%
label-warn-foreground = ${colors.secondary}

ramp-0 = яЛЛ
ramp-1 = яЛК
ramp-2 = яЛЙ
ramp-3 = яЛИ
ramp-4 = яЛЗ
ramp-foreground = ${colors.foreground-alt}
ramp-font = 1

[module/powermenu]
type = custom/menu

expand-right = true

format-spacing = 1

label-open = яАС
label-open-padding = 1
;label-open-foreground = ${colors.secondary}
label-open-background = ${colors.secondary}
label-close = "%{T3}яРР%{T-} cancel"
;label-close-font = 3
label-close-foreground = ${colors.secondary}
label-separator = |
label-separator-foreground = ${colors.foreground-alt}

menu-0-0 = reboot
menu-0-0-exec = menu-open-1
menu-0-1 = power off
menu-0-1-exec = menu-open-2

menu-1-0 = cancel
menu-1-0-exec = menu-open-0
menu-1-1 = reboot
menu-1-1-exec = sudo reboot

menu-2-0 = power off
menu-2-0-exec = sudo poweroff
menu-2-1 = cancel
menu-2-1-exec = menu-open-0

[settings]
screenchange-reload = true
;compositing-background = xor
;compositing-background = screen
;compositing-foreground = source
;compositing-border = over

[global/wm]
; margin-top = 5
; margin-bottom = 5

